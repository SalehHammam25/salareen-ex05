# Environment variable template for salareen-ex05
# Copy this file to .env and fill in values as needed.
# The .env file is git-ignored — never commit secrets.

# Hugging Face token (only needed for gated models such as Llama-3)
# Leave empty if using openly-downloadable models (Phi-3, Qwen2, TinyLlama, etc.)
HF_TOKEN=

# Optional: override default model cache directory
# By default HuggingFace caches to C:\Users\<user>\.cache\huggingface
# Set this to a drive with more free space if C: is low.
HF_HOME=

# Number of CPU threads to use for inference (0 = all available)
NUM_THREADS=0

# Maximum wall-clock seconds to allow per inference run before aborting
INFERENCE_TIMEOUT_SEC=600

# API keys for economic comparison (never used for actual inference in this project)
# Only used by costs.py to fetch current pricing — leave blank to use hardcoded defaults.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
